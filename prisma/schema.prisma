// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OttMissDirection {
  LEFT
  HIT
  RIGHT
}

enum AppMissDirection {
  LEFT
  RIGHT
  SHORT
  LONG
}

enum RoundStatus {
  IN_PROGRESS
  COMPLETED
}

enum CoachMessageRole {
  USER
  ASSISTANT
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  rounds        Round[]
  coachMessages CoachMessage[]
  createdAt     DateTime       @default(now())
}

model Round {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  courseName        String
  externalCourseId  Int?
  courseLatitude    Float?
  courseLongitude   Float?
  teeName           String?
  holeCount         Int      @default(18)
  coursePar         Int?

  // Aggregates (computed from holes on save; kept for dashboard + legacy rounds)
  totalScore     Int
  fairwaysHit    Int
  greensInReg    Int
  totalPutts     Int
  penaltyStrokes Int      @default(0)

  aiFeedback     String?  @db.Text
  date           DateTime @default(now())
  status         RoundStatus @default(COMPLETED)
  holes          Hole[]
  coachMessages  CoachMessage[]
}

model CoachMessage {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  roundId   String?
  round     Round?           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  role      CoachMessageRole
  content   String           @db.Text
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([roundId, createdAt])
}

/// Cached per-hole tee/green GPS. Keyed by golfcourseapi id or course name + coordinates.
model CourseGpsCache {
  id               String   @id @default(cuid())
  cacheKey         String   @unique
  externalCourseId Int?
  courseName       String?
  payload          Json
  /// osm | manual | igolf | golfbert | golfintelligence
  source           String
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([externalCourseId])
}

model Hole {
  id                String            @id @default(cuid())
  roundId           String
  round             Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)

  holeNumber        Int
  par               Int?
  yardage           Int?
  score             Int
  putts             Int
  penaltyStrokes    Int               @default(0)

  // Off-the-Tee (par 4/5 only; null on par 3)
  ottMissDirection  OttMissDirection?

  // Approach
  gir               Boolean
  appMissDirection  AppMissDirection?
  approachProximity Int?

  // Around-the-Green (when GIR missed)
  upAndDownAttempt  Boolean?
  upAndDownSuccess  Boolean?
  argProximity      Int?

  // Set true when the player saves hole stats during live play
  touched           Boolean           @default(false)

  @@unique([roundId, holeNumber])
}
