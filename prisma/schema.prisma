// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OttMissDirection {
  LEFT
  HIT
  RIGHT
}

enum AppMissDirection {
  LEFT
  RIGHT
  SHORT
  LONG
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  rounds    Round[]
  createdAt DateTime @default(now())
}

model Round {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  courseName        String
  externalCourseId  Int?
  teeName           String?
  holeCount         Int      @default(18)
  coursePar         Int?

  // Aggregates (computed from holes on save; kept for dashboard + legacy rounds)
  totalScore     Int
  fairwaysHit    Int
  greensInReg    Int
  totalPutts     Int
  penaltyStrokes Int      @default(0)

  aiFeedback     String?  @db.Text
  date           DateTime @default(now())
  holes          Hole[]
}

model Hole {
  id                String            @id @default(cuid())
  roundId           String
  round             Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)

  holeNumber        Int
  par               Int?
  yardage           Int?
  score             Int
  putts             Int
  penaltyStrokes    Int               @default(0)

  // Off-the-Tee (par 4/5 only; null on par 3)
  ottMissDirection  OttMissDirection?

  // Approach
  gir               Boolean
  appMissDirection  AppMissDirection?
  approachProximity Int?

  // Around-the-Green (when GIR missed)
  upAndDownAttempt  Boolean?
  upAndDownSuccess  Boolean?
  argProximity      Int?

  @@unique([roundId, holeNumber])
}
